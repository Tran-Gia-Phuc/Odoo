<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- FORM VIEW -->
        <record id="pos_combo_form_view_inherit" model="ir.ui.view">
            <field name="name">pos.combo.form.view.inherit</field>
            <field name="model">pos.combo</field>
            <field name="inherit_id" ref="point_of_sale.view_pos_combo_form" />
            <field name="arch" type="xml">

                <!-- Thêm sau div oe_title -->
                <xpath expr="//div[@class='oe_title']" position="after">
                    <group>
                        <group>
                            <field name="date_start" />
                            <field name="date_end" />
                        </group>
                        <group>
                            <field name="description" />
                        </group>
                    </group>
                </xpath>

            </field>
        </record>
        <!-- TREE VIEW -->
        <record id="pos_combo_tree_view_inherit" model="ir.ui.view">
            <field name="name">pos.combo.tree.view.inherit</field>
            <field name="model">pos.combo</field>
            <field name="inherit_id" ref="point_of_sale.view_pos_combo_tree" />
            <field name="arch" type="xml">

                <!-- <xpath expr="//field[@name='num_of_products']" position="before">
                    <field name="write_date" readonly="1" />
                </xpath> -->

                <field name="num_of_products" position="after">
                    <field name="date_start" />
                    <field name="date_end" />
                </field>

            </field>
        </record>

    </data>
</odoo>