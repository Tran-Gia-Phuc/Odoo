<odoo>
    <!-- Form view -->
    <record id="view_class_form" model="ir.ui.view">
        <field name="name">class.form</field>
        <field name="model">demo.student_class</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <button name="action_open_assign_wizard"
                        string="Add Existing Student"
                        type="object"
                        class="btn-primary" />
                    <group>
                        <field name="name" />
                    </group>
                    <notebook>
                        <page string="Students">
                            <field name="student_ids" domain="[('class_id', '=', False)]">
                                <tree>
                                    <field name="name" />
                                    <field name="age" />
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Tree view -->
    <record id="view_class_tree" model="ir.ui.view">
        <field name="name">class.tree</field>
        <field name="model">demo.student_class</field>
        <field name="arch" type="xml">
            <tree>
                <field name="name" />
            </tree>
        </field>
    </record>

    <!-- Action -->
    <record id="action_class" model="ir.actions.act_window">
        <field name="name">Classes</field>
        <field name="res_model">demo.student_class</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_class" name="Classes" parent="menu_student_root" action="action_class" />
</odoo>