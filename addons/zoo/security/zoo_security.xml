<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Tạo danh mục (category) để nhóm các group lại -->
    <record id="zoo.module_category_zoo_hr_employees" model="ir.module.category">
        <field name="name">Zoo City</field>
        <field name="sequence">10</field>
    </record>

     <record id="group_zoo_user" model="res.groups">
        <field name="name">Zoo User</field>
        <field name="category_id" ref="zoo.module_category_zoo_hr_employees"/>
        <!-- implied_ids: kế thừa quyền từ group_user (internal user) -->
        <field name="implied_ids" eval="[(6, 0, [ref('base.group_user')])]"/>
    </record>

     <record id="group_zoo_manager" model="res.groups">
        <field name="name">Zoo Manager</field>
        <field name="category_id" ref="zoo.module_category_zoo_hr_employees"/>
         <field name="implied_ids" eval="[(4, ref('group_zoo_user'))]"/>
         <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- Zoo Super Manager (quản lý) -->
    <record id="group_zoo_super_manager" model="res.groups">
        <field name="name">Zoo Super Manager</field>
        <field name="category_id" ref="zoo.module_category_zoo_hr_employees"/>
        <!-- Kế thừa toàn bộ quyền của Zoo Manager -->
        <field name="implied_ids" eval="[(4, ref('group_zoo_manager'))]"/>
    </record>





        <!-- ... -->    
    <record id="zoo_manager_see_his_animal" model="ir.rule">
        <field name="name">Zoo Manager See His Animal</field>
        <field name="model_id" ref="model_zoo_animal"/>
        <field name="domain_force">['|',('create_uid','=',user.id),('create_uid','=',False)]</field>
        <field name="groups" eval="[(4, ref('zoo.group_zoo_manager'))]"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_unlink" eval="1"/>
        <field name="perm_read" eval="1"/>
    </record>
</odoo>