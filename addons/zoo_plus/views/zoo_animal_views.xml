<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="zoo_animal_form_view_inherit" model="ir.ui.view">
            <field name="name">zoo.animal.form.view.inherit</field>
            <field name="model">zoo.animal</field>
            <field name="inherit_id" ref="zoo.zoo_animal_form_view"/>
            <field name="arch" type="xml">

                <!-- Giữ nguyên header, chỉ thêm Send SMS -->
                <xpath expr="//header" position="inside">
                    <button name="send_sms" type="object" string="Send SMS" class="oe_highlight"/>
                </xpath>

                <!-- Làm to tên hơn -->
                <xpath expr="//div[@class='oe_title']/h1/field[@name='name']" position="attributes">
                    <attribute name="style">font-size: 2.5rem;</attribute>
                </xpath>

                <!-- Xóa toàn bộ group basic_information, thay bằng layout mới -->
                <xpath expr="//group[@name='basic_information']" position="replace">
                    <group>
                        <!-- CỘT TRÁI: ảnh -->
                        <group>
                            <field name="image" widget="image" 
                                   options="{'size': [512, 512]}"
                                   nolabel="1"/>
                        </group>

                        <!-- CỘT PHẢI: 2 cột field -->
                        <group >
                            <group >
                                <field name="is_feed_by_visitor"/>
                                <field name="nickname"/>
                                <field name="dob"/>
                                <field name="age" string="Pet Age"/>
                                <field name="weight" string="Weight of animal (kg)"/>
                                <field name="cage_id" options="{'no_create_edit': True, 'no_open': True}"/>
                                <field name="feed_time"/>
                                <field name="mother_name"/>
                                <field name="beensold"/>
                            </group>
                            <group>
                                <field name="feed_visitor_message"/>
                                <field name="gender"/>
                                <field name="creature_id"/>
                                <field name="doctor_id"/>
                                <field name="mother_id"/>
                                <field name="father_id"/>
                                <field name="price"/>
                            </group>
                        </group>
                    </group>
                </xpath>

                <!-- Thêm write_date, create_date vào page User Access -->
                <notebook name="misc" position="inside">
                    <page name="uid" string="User Access">
                        <group>
                            <group>
                                <field name="write_uid"/>
                                <field name="write_date" readonly="1"/>
                                <field name="create_date" readonly="1"/>
                            </group>
                            <group/>
                        </group>
                    </page>
                </notebook>

                <!-- Ẩn page Children -->
                <page name="children" position="attributes">
                    <attribute name="invisible">1</attribute>
                </page>

                <!-- Xóa weight_pound -->
                <!-- <xpath expr="//field[@name='weight_pound']" position="replace"/> -->

            </field>
        </record>
    </data>
</odoo>


